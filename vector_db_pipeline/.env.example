# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# --- Qdrant Cloud ---
QDRANT_URL=https://your-cluster-id.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# --- vLLM server (Qwen3.5-VL-9B) ---
# Local:   http://localhost:8000/v1
# RunPod:  https://<pod-id>-8000.proxy.runpod.net/v1
# AWS EC2: http://<public-ip>:8000/v1
VLLM_API_BASE=http://localhost:8000/v1

# --- Google Cloud (for Cloud Run Job) ---
GCP_PROJECT_ID=your-gcp-project-id
GCS_BUCKET=gs://your-bucket-name

# --- LlamaParse (optional, only if using llamaparse backend) ---
LLAMA_CLOUD_API_KEY=

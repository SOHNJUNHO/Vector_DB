# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# --- Qdrant Cloud (free tier: cloud.qdrant.io) ---
QDRANT_URL=https://your-cluster-id.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# --- VLM inference ---
# Fireworks AI (recommended — no GPU setup, pay per token):
#   API base : https://api.fireworks.ai/openai/v1
#   Model    : accounts/fireworks/models/qwen2-vl-72b-instruct
#
# Local vLLM (if you have a GPU):
#   API base : http://localhost:8000/v1
#   Model    : Qwen/Qwen3.5-VL-9B
VLLM_API_BASE=https://api.fireworks.ai/openai/v1
FIREWORKS_API_KEY=your-fireworks-api-key

# --- LlamaParse (optional, only if using llamaparse backend) ---
LLAMA_CLOUD_API_KEY=
